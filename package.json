{
  "name": "eatingtoken-zh",
  "displayName": "Token 统计 - Copilot Token 追踪器",
  "description": "实时追踪 GitHub Copilot 的 Token 消耗量和预估费用。清楚知道你吃了多少 Token。",
  "version": "0.2.2",
  "publisher": "kebin988",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "tokens",
    "usage",
    "cost",
    "metrics",
    "ai",
    "tracking"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kebin988/eatingtoken-zh"
  },
  "contributes": {
    "commands": [
      {
        "command": "eatingtoken.showDashboard",
        "title": "Eating Token: 显示仪表盘"
      },
      {
        "command": "eatingtoken.resetSession",
        "title": "Eating Token: 重置会话统计"
      },
      {
        "command": "eatingtoken.exportData",
        "title": "Eating Token: 导出使用数据"
      }
    ],
    "configuration": {
      "title": "Eating Token",
      "properties": {
        "eatingtoken.costModel": {
          "type": "string",
          "default": "gpt-4o",
          "enum": [
            "gpt-4o",
            "gpt-4o-mini",
            "gpt-4.1",
            "gpt-4",
            "claude-opus-4.6",
            "claude-sonnet-4",
            "claude-sonnet-3.5"
          ],
          "description": "用于费用估算的模型定价。由于 Copilot 内部定价未公开，此处按等价 API 费率估算。"
        },
        "eatingtoken.contextMultiplier": {
          "type": "number",
          "default": 1.3,
          "description": "应用于可见上下文的乘数，用于估算 Copilot 完整提示（包含相邻标签页、文件路径等）"
        },
        "eatingtoken.showInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "在状态栏显示 Token 消耗"
        },
        "eatingtoken.statusBarFormat": {
          "type": "string",
          "default": "tokens-and-cost",
          "enum": [
            "tokens-only",
            "cost-only",
            "tokens-and-cost"
          ],
          "description": "状态栏显示内容格式"
        },
        "eatingtoken.trackCompletions": {
          "type": "boolean",
          "default": true,
          "description": "追踪内联补全接受情况（基于启发式算法）"
        },
        "eatingtoken.yearlyTarget": {
          "type": "number",
          "default": 1812500,
          "description": "年度消费目标（人民币元），默认 181.25 万元（约 25 万美元，灵感来自黄仁勋基准）"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "eatingtoken",
          "title": "Token 追踪",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "eatingtoken": [
        {
          "id": "eatingtoken.dashboardView",
          "name": "仪表盘",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "eatingtoken.acceptSuggestion",
        "key": "tab",
        "when": "inlineSuggestionVisible && !editorTabMovesFocus && config.eatingtoken.trackCompletions"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap && node -e \"require('fs').copyFileSync('node_modules/chart.js/dist/chart.umd.min.js','dist/chart.umd.min.js')\"",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "gpt-tokenizer": "^2.8.0"
  }
}
